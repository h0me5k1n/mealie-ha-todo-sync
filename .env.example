# Home Assistant base URL (no trailing slash)
HA_URL=http://homeassistant.local:8123

# Long-lived access token from HA Profile > Security > Long-Lived Access Tokens
HA_TOKEN=your_token_here

# The Mealie shopping list mirrored as a HA todo entity.
# NOTE: this entity only appears after you create a shopping list inside Mealie first.
# Find yours: HA Developer Tools > States, filter by todo., look for todo.mealie_
MEALIE_TODO_ENTITY=todo.mealie_your_list_name

# Any HA todo entity to sync into (OurGroceries, Bring!, Todoist, native list, etc.)
DESTINATION_TODO_ENTITY=todo.shopping_list

# Optional tag appended/prepended to synced items.
# Leave empty (default) — items are marked complete in Mealie after sync so they
# won't reappear, making a tag unnecessary. Set to e.g. [Mealie] if you want
# a visible label on synced items in the destination list.
ITEM_TAG=

# Where the tag appears: suffix (default) or prefix — only used when ITEM_TAG is set
# suffix → "2 chicken breasts [Mealie]"
# prefix → "[Mealie] 2 chicken breasts"
ITEM_TAG_POSITION=suffix

# Set to false to disable OpenTelemetry tracing entirely (no collector needed).
# There's no bundled collector for local dev — leave this false unless you're
# pointing OTEL_EXPORTER_OTLP_ENDPOINT at a collector you run yourself.
OTEL_ENABLED=false

# OTel Collector gRPC endpoint (host:port, no scheme) — ignored when OTEL_ENABLED=false.
# In production this points at your shared observability stack's OTLP receiver.
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
